<Window
    x:Class="XamlIconViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Converter="clr-namespace:XamlIconViewer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XamlIconViewer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Path=WindowTitel, FallbackValue=WindowTitel}"
    Width="800"
    Height="500"
    mc:Ignorable="d">
    <Window.Icon>
        <BitmapImage UriSource="pack://application:,,,/Resources/Picture/ApplicationIcon.png" />
    </Window.Icon>

    <Window.Resources>
        <Converter:ShortFolderNameConverter x:Key="ShortFolderNameConverter" />
    </Window.Resources>

    <Grid x:Name="gridMain">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition
                Width="0.3*"
                MinWidth="100"
                MaxWidth="300" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="10,0,0,0"
            Orientation="Horizontal">
            <RadioButton
                x:Name="rbCanvas"
                VerticalAlignment="Center"
                Content="Canvas"
                GroupName="ICON" />

            <RadioButton
                x:Name="rbViewbox"
                Margin="5,0,0,0"
                VerticalAlignment="Center"
                Content="Viewbox"
                GroupName="ICON" />

            <CheckBox Margin="10,0,0,0"
                x:Name="chkKonvertieren"
                VerticalAlignment="Center"
                Content="ViewBox nach DrawingImage konvertieren"
                IsChecked="False" />

            <RadioButton
                x:Name="rbDrawingImage"
                Margin="5,0,0,0"
                VerticalAlignment="Center"
                Content="DrawingImage"
                GroupName="ICON" />

            <RadioButton
                x:Name="rbPathGeometry"
                Margin="5,0,0,0"
                VerticalAlignment="Center"
                Content="PathGeometry"
                GroupName="ICON" />

            <RadioButton
                x:Name="rbSVG"
                Margin="5,0,0,0"
                VerticalAlignment="Center"
                Content="SVG"
                GroupName="ICON" />
        </StackPanel>

        <ListBox
            x:Name="lbFiles"
            Grid.Row="1"
            Grid.Column="0"
            Margin="5,0,0,5"
            VerticalAlignment="Stretch"
            ItemsSource="{Binding Path=ImageListSource, UpdateSourceTrigger=PropertyChanged}"
            SelectedIndex="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding ., Converter={StaticResource ResourceKey=ShortFolderNameConverter}}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <GridSplitter
            Grid.Row="1"
            Grid.Column="1"
            Width="5"
            HorizontalAlignment="Stretch"
            ResizeDirection="Columns">
            <GridSplitter.Template>
                <ControlTemplate TargetType="{x:Type GridSplitter}">
                    <Grid x:Name="gridSplitter" Panel.ZIndex="0">
                        <Rectangle
                            Width="3"
                            Panel.ZIndex="-2"
                            Fill="LightGray"
                            IsHitTestVisible="False"
                            Opacity="1" />

                        <Border
                            x:Name="borderSymbol"
                            Width="25"
                            Height="25"
                            Margin="-13,0"
                            Panel.ZIndex="2"
                            Background="White"
                            BorderBrush="Blue"
                            BorderThickness="0.75"
                            CornerRadius="25"
                            Visibility="Visible">
                            <Path
                                Width="17"
                                Height="7"
                                Panel.ZIndex="0"
                                Data="m 4.4549201,1048.4664 -4.33056515,1.9095 4.33056515,1.9094 0,-3.8189 z m 3.0901599,0 0,3.8189 4.330565,-1.9094 -4.330565,-1.9095 z m -3.2239449,0.2053 0,3.4083 -3.86518514,-1.7041 3.86518514,-1.7042 z m 3.3577349,0 3.865185,1.7042 -3.865185,1.7041 0,-3.4083 z"
                                Stretch="Fill"
                                Stroke="Black"
                                StrokeThickness="0.5" />
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger SourceName="gridSplitter" Property="IsMouseOver" Value="True">
                            <Setter TargetName="borderSymbol" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <Border
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.Column="2"
            Margin="5,0,0,5"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Panel.ZIndex="-1"
            Background="Transparent"
            BorderBrush="DarkBlue"
            BorderThickness="2"
            CornerRadius="5">
            <Image
                x:Name="ImagesView"
                Margin="5"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Stretch="None" />
        </Border>

    </Grid>
</Window>
